{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "sidecar-permissions",
    "windows": [
        "main"
    ],
    "permissions": [
        "core:default",
        "shell:default",
        "notification:default",
        {
            "identifier": "shell:allow-execute",
            "allow": [
                {
                    "name": "python-sidecar",
                    "cmd": "python3",
                    "args": true
                },
                {
                    "name": "uv-run",
                    "cmd": "uv",
                    "args": true
                }
            ]
        }
    ]
}