{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Neural Forge",
  "version": "1.0.0-beta",
  "identifier": "com.neuralforge.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Neural Forge",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true,
        "theme": "Dark",
        "titleBarStyle": "Visible",
        "url": "index.html"
      }
    ],
    "trayIcon": {
      "iconPath": "icons/tray.png",
      "iconAsTemplate": true,
      "tooltip": "Neural Forge"
    },
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:7731 ws://localhost:7731; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data: blob:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../python_sidecar/**/*"
    ],
    "category": "Education",
    "shortDescription": "Gamified ML skill acquisition OS",
    "longDescription": "Neural Forge is a fullscreen desktop application for machine learning skill acquisition. Skill trees, spaced repetition, local AI tutor, knowledge graph, and collaborative study rooms.",
    "linux": {
      "deb": {
        "depends": [
          "python3",
          "python3-pip"
        ]
      }
    },
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "signingIdentity": null,
      "providerShortName": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    },
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": [],
      "dialog": true,
      "pubkey": ""
    }
  }
}